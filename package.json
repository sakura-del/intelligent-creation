{
  "name": "ai-resume",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && cd server && npm test -- --coverage",
    "test:ci": "npm run test:run -- --coverage && cd server && npm test -- --coverage",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.48.0",
    "axios": "^1.14.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "marked": "^15.0.12",
    "monaco-editor": "^0.55.1",
    "monaco-editor-vue3": "^1.0.5",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "sass": "^1.99.0",
    "vue": "^3.5.31",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^9.14.4",
    "vue-router": "^5.0.4",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
